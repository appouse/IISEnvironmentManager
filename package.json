{
  "name": "iis-environment-controller",
  "version": "1.0.9",
  "description": "IIS Application Pool ve Environment Variable yönetim aracı",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/appouse/IISEnvironmentController.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "npx @electron/packager . \"IIS Environment Controller\" --platform=win32 --arch=x64 --out=dist --overwrite --asar",
    "postbuild": "node scripts/postbuild.js",
    "release": "npm run build && npm run postbuild",
    "sendRelease": "npm version patch && git push origin main --tags"
  },
  "author": "Appouse",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "com.appouse.iis-environment-controller",
    "productName": "IIS Environment Controller",
    "copyright": "Copyright © 2026 Appouse. Tüm hakları saklıdır.",
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator",
      "legalTrademarks": "Appouse",
      "publisherName": "Appouse"
    },
    "portable": {
      "artifactName": "IISEnvironmentController.exe"
    },
    "forceCodeSigning": false
  },
  "updateConfig": {
    "url": "https://raw.githubusercontent.com/appouse/IISEnvironmentManager/main/version.json"
  }
}
