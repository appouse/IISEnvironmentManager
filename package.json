{
  "name": "iis-environment-controller",
  "version": "1.0.0",
  "description": "IIS Application Pool ve Environment Variable yönetim aracı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npx @electron/packager . \"IIS Environment Controller\" --platform=win32 --arch=x64 --out=dist --overwrite --asar"
  },
  "author": "Appouse",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "com.appouse.iis-environment-controller",
    "productName": "IIS Environment Controller",
    "copyright": "Copyright © 2026 Appouse. Tüm hakları saklıdır.",
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator",
      "legalTrademarks": "Appouse",
      "publisherName": "Appouse"
    },
    "portable": {
      "artifactName": "IISEnvironmentController.exe"
    },
    "forceCodeSigning": false
  }
}
