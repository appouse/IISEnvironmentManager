{
  "name": "iis-environment-controller",
  "version": "1.0.0",
  "description": "IIS Application Pool ve Environment Variable yönetim aracı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Appouse",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "com.iis.environment-controller",
    "productName": "IIS Environment Controller",
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
